{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/pages/home.html"
    },
    {
      "source": "/login",
      "destination": "/frontend/pages/login.html"
    },
    {
      "source": "/signup",
      "destination": "/frontend/pages/signup.html"
    },
    {
      "source": "/aptitude",
      "destination": "/frontend/pages/aptitude.html"
    },
    {
      "source": "/coding",
      "destination": "/frontend/pages/coding-questions.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
